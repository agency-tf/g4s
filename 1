<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Plataforma Operativa G4S</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    body { font-family: system-ui, -apple-system, sans-serif; background-color: #f8fafc; }
    .glass-card { background: rgba(255, 255, 255, 0.98); backdrop-filter: blur(10px); }
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
  </style>
</head>
<body class="text-slate-800 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] min-h-screen flex flex-col">

  <div id="toast" class="fixed top-4 right-4 z-50 transform translate-y-[-100%] opacity-0 transition-all duration-300 px-5 py-3 rounded-xl shadow-xl flex items-center gap-3 text-white text-sm font-bold pointer-events-none">
    <i id="toastIcon" class="fas"></i><span id="toastMessage"></span>
  </div>

  <!-- PANTALLA LOGIN -->
  <div id="pantalla-login" class="flex-1 flex items-center justify-center p-4">
    <div class="glass-card p-8 rounded-3xl shadow-2xl w-full max-w-sm border border-slate-200">
      <div class="text-center mb-6">
        <div class="w-16 h-16 bg-rose-50 text-rose-600 rounded-2xl flex items-center justify-center text-3xl mx-auto mb-4 border border-rose-100"><i class="fa-solid fa-shield-halved"></i></div>
        <h1 class="text-2xl font-black text-slate-900 tracking-tight">Acceso Operativo</h1>
      </div>
      
      <form id="form-login" onsubmit="ejecutarLogin(event)" class="space-y-4">
        <div>
          <label class="block text-[10px] font-black uppercase text-slate-400 mb-1 ml-1">Usuario / ID</label>
          <div class="relative"><i class="fas fa-user absolute left-4 top-4 text-slate-400"></i><input type="text" id="login-user" required class="w-full pl-10 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-xl outline-none focus:border-rose-500 font-medium"></div>
        </div>
        <div>
          <label class="block text-[10px] font-black uppercase text-slate-400 mb-1 ml-1">Contraseña</label>
          <div class="relative"><i class="fas fa-lock absolute left-4 top-4 text-slate-400"></i><input type="password" id="login-pass" required class="w-full pl-10 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-xl outline-none focus:border-rose-500 font-medium"></div>
        </div>
        <button type="submit" id="btn-login" class="w-full py-3.5 bg-slate-900 hover:bg-rose-600 text-white rounded-xl font-bold transition-colors flex justify-center items-center gap-2 mt-4">
          <span>Ingresar al Sistema</span>
        </button>
      </form>
    </div>
  </div>

  <!-- PANTALLA APLICACIÓN -->
  <div id="pantalla-app" class="hidden flex-1 flex flex-col">
    <nav class="bg-slate-900 text-white p-4 shadow-md z-10">
      <div class="max-w-6xl mx-auto flex justify-between items-center">
        <div class="flex items-center gap-3">
          <div class="bg-rose-600 text-white font-black px-3 py-1.5 rounded-lg tracking-wider">G4S</div>
          <div><h1 class="font-black text-lg leading-tight">Gestión Operativa</h1><p class="text-[10px] text-slate-400 uppercase tracking-widest">Agente: <span id="ui-username" class="text-rose-400"></span></p></div>
        </div>
        <button onclick="cerrarSesion()" class="bg-slate-800 hover:bg-rose-600 px-4 py-2 rounded-xl text-xs font-bold transition-colors"><i class="fas fa-power-off mr-1"></i> Salir</button>
      </div>
    </nav>

    <div class="bg-slate-800 border-b border-slate-700">
      <div class="max-w-6xl mx-auto flex gap-1 p-2 overflow-x-auto hide-scrollbar">
        <button onclick="cambiarTab('tab-clientes')" id="btn-tab-clientes" class="tab-btn px-5 py-2.5 rounded-lg text-sm font-bold bg-rose-600 text-white"><i class="fas fa-users mr-1"></i> Directorio</button>
        <button onclick="cambiarTab('tab-actas')" id="btn-tab-actas" class="tab-btn px-5 py-2.5 rounded-lg text-sm font-bold text-slate-300 hover:bg-slate-700"><i class="fas fa-file-signature mr-1"></i> Redactar Acta</button>
        <button onclick="cambiarTab('tab-historial')" id="btn-tab-historial" class="tab-btn px-5 py-2.5 rounded-lg text-sm font-bold text-slate-300 hover:bg-slate-700"><i class="fas fa-folder-open mr-1"></i> Historial y Filtros</button>
      </div>
    </div>

    <div class="max-w-6xl mx-auto w-full p-4 sm:p-6">
      <div id="tab-clientes" class="tab-content"><div class="bg-white border border-slate-200 rounded-2xl shadow-sm p-6 max-w-3xl"><h2 class="text-xl font-black text-slate-800 mb-4"><i class="fas fa-building text-rose-500 mr-2"></i>Registrar Entidad</h2><form id="form-cliente" onsubmit="registrarCliente(event)" class="grid grid-cols-1 sm:grid-cols-2 gap-4"><div><label class="block text-[10px] font-bold text-slate-400 uppercase mb-1">Nombre Entidad *</label><input type="text" id="cli-nombre" required class="w-full p-3 bg-slate-50 border border-slate-200 rounded-xl outline-none focus:border-rose-500 text-sm"></div><div><label class="block text-[10px] font-bold text-slate-400 uppercase mb-1">Correo Electrónico *</label><input type="email" id="cli-correo" required class="w-full p-3 bg-slate-50 border border-slate-200 rounded-xl outline-none focus:border-rose-500 text-sm"></div><div><label class="block text-[10px] font-bold text-slate-400 uppercase mb-1">Dirección Física</label><input type="text" id="cli-direccion" class="w-full p-3 bg-slate-50 border border-slate-200 rounded-xl outline-none focus:border-rose-500 text-sm"></div><div><label class="block text-[10px] font-bold text-slate-400 uppercase mb-1">Teléfono</label><input type="text" id="cli-telefono" class="w-full p-3 bg-slate-50 border border-slate-200 rounded-xl outline-none focus:border-rose-500 text-sm"></div><div><label class="block text-[10px] font-bold text-slate-400 uppercase mb-1">Representante</label><input type="text" id="cli-cargo" class="w-full p-3 bg-slate-50 border border-slate-200 rounded-xl outline-none focus:border-rose-500 text-sm"></div><div class="sm:col-span-2 pt-2"><button type="submit" id="btn-cliente" class="px-6 py-3 bg-slate-900 text-white rounded-xl font-bold hover:bg-rose-600 transition-colors"><i class="fas fa-save mr-1"></i> Guardar Cliente</button></div></form></div></div>
      <div id="tab-actas" class="tab-content hidden"><div class="bg-white border border-slate-200 rounded-2xl shadow-sm p-6"><h2 class="text-xl font-black text-slate-800 mb-1"><i class="fas fa-file-contract text-rose-500 mr-2"></i>Emitir Acta Oficial</h2><form id="form-acta" onsubmit="generarActa(event)" class="grid grid-cols-1 lg:grid-cols-2 gap-6 mt-4"><div class="space-y-4"><div><label class="block text-[10px] font-bold text-slate-400 uppercase mb-1">Seleccionar Cliente *</label><select id="act-cliente" onchange="autoCompletarCliente()" required class="w-full p-3 bg-slate-50 border border-slate-200 rounded-xl text-sm font-bold outline-none focus:border-rose-500"></select></div><div class="grid grid-cols-2 gap-4"><div><label class="block text-[10px] font-bold text-slate-400 uppercase mb-1">Fecha</label><input type="date" id="act-fecha" required class="w-full p-3 bg-slate-50 border border-slate-200 rounded-xl text-sm"></div><div><label class="block text-[10px] font-bold text-slate-400 uppercase mb-1">Ciudad</label><input type="text" id="act-ciudad" required class="w-full p-3 bg-slate-50 border border-slate-200 rounded-xl text-sm"></div></div><div><label class="block text-[10px] font-bold text-slate-400 uppercase mb-1">Lugar Reunión</label><input type="text" id="act-direccion" required class="w-full p-3 bg-slate-50 border border-slate-200 rounded-xl text-sm"></div><div class="grid grid-cols-2 gap-4"><div><label class="block text-[10px] font-bold text-slate-400 uppercase mb-1">Asistentes Cliente</label><input type="text" id="act-asist-cli" required class="w-full p-3 bg-slate-50 border border-slate-200 rounded-xl text-sm"></div><div><label class="block text-[10px] font-bold text-slate-400 uppercase mb-1">Cargo Cliente</label><input type="text" id="act-cargo-cli" required class="w-full p-3 bg-slate-50 border border-slate-200 rounded-xl text-sm"></div></div></div><div class="space-y-4 flex flex-col"><div class="grid grid-cols-2 gap-4"><div><label class="block text-[10px] font-bold text-slate-400 uppercase mb-1">Asistentes G4S</label><input type="text" id="act-asist-g4s" required class="w-full p-3 bg-slate-50 border border-slate-200 rounded-xl text-sm"></div><div><label class="block text-[10px] font-bold text-slate-400 uppercase mb-1">Cargo G4S</label><input type="text" id="act-cargo-g4s" required class="w-full p-3 bg-slate-50 border border-slate-200 rounded-xl text-sm"></div></div><div class="flex-1"><label class="block text-[10px] font-bold text-slate-400 uppercase mb-1">Temas Tratados</label><textarea id="act-temas" required class="w-full h-24 p-3 bg-slate-50 border border-slate-200 rounded-xl text-sm resize-none"></textarea></div><div class="flex-1"><label class="block text-[10px] font-bold text-slate-400 uppercase mb-1">Conclusiones</label><textarea id="act-conclusiones" required class="w-full h-24 p-3 bg-slate-50 border border-slate-200 rounded-xl text-sm resize-none"></textarea></div><input type="hidden" id="act-correo-cli"><div class="flex items-center gap-2"><input type="checkbox" id="act-descargar" class="w-4 h-4 rounded text-rose-600"><label class="text-xs font-bold text-slate-600">Descargar PDF al finalizar</label></div><button type="submit" id="btn-acta" class="w-full py-4 bg-rose-600 text-white rounded-xl font-black hover:bg-rose-700 shadow-lg mt-2 transition-all"><i class="fas fa-paper-plane mr-2"></i> Emitir Acta Oficial</button></div></form></div></div>
      <div id="tab-historial" class="tab-content hidden"><div class="bg-white border border-slate-200 rounded-2xl shadow-sm overflow-hidden"><div class="p-4 border-b border-slate-100 bg-slate-50 flex justify-between items-center"><h2 class="text-lg font-black text-slate-800"><i class="fas fa-search text-rose-500 mr-2"></i>Auditoría</h2><button onclick="cargarHistorial()" class="text-slate-600 hover:text-rose-600 text-xs font-bold"><i class="fas fa-sync-alt mr-1"></i> Recargar</button></div><div class="p-4 bg-slate-50/50 border-b border-slate-100 grid grid-cols-1 sm:grid-cols-3 gap-4"><div><label class="block text-[10px] font-black uppercase text-slate-400 mb-1 ml-1">Desde</label><input type="date" id="filtro-desde" onchange="aplicarFiltros()" class="w-full p-2.5 bg-white border border-slate-200 rounded-lg text-sm outline-none"></div><div><label class="block text-[10px] font-black uppercase text-slate-400 mb-1 ml-1">Hasta</label><input type="date" id="filtro-hasta" onchange="aplicarFiltros()" class="w-full p-2.5 bg-white border border-slate-200 rounded-lg text-sm outline-none"></div><div><label class="block text-[10px] font-black uppercase text-slate-400 mb-1 ml-1">Cliente</label><input type="text" id="filtro-cliente" oninput="aplicarFiltros()" placeholder="Buscar..." class="w-full p-2.5 bg-white border border-slate-200 rounded-lg text-sm outline-none"></div></div><div class="overflow-x-auto"><table class="w-full text-left border-collapse min-w-[600px]"><thead class="bg-white border-b border-slate-200 text-[10px] font-black text-slate-400 uppercase"><tr><th class="p-4">Expediente</th><th class="p-4">Fecha</th><th class="p-4">Cliente</th><th class="p-4">Ciudad</th><th class="p-4">Síntesis</th></tr></thead><tbody id="tabla-historial" class="divide-y divide-slate-100 text-sm"><tr><td colspan="5" class="p-8 text-center text-slate-400">Haz clic en Recargar.</td></tr></tbody></table></div></div></div>
    </div>
  </div>

  <script>
    // URL DE LA APP - REQUERIDA POR EL USUARIO PARA RECARGAS LIMPIAS
    const APP_URL = "https://script.google.com/macros/s/AKfycbxa8gQkztIRVGN9-jsPY3ab15gA0kKhuPlK3yz4C6rvJz1GmVxnykEbGBmkK5pTWqVAxQ/exec";

    let sessionUser = null; let dbClientes = []; let dbHistorial = [];

    async function pushData(action, data) {
      try {
        const response = await fetch(APP_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'text/plain;charset=utf-8' },
          body: JSON.stringify({ action: action, data: data })
        });
        const text = await response.text();
        return JSON.parse(text);
      } catch (err) {
        return { success: false, message: "Error de conexión: " + err.message };
      }
    }

    window.onload = function() {
      const stored = sessionStorage.getItem('g4s_user');
      if (stored) { sessionUser = JSON.parse(stored); activarDashboard(); }
    };

    function mostrarToast(msg, tipo = 'success') {
      const toast = document.getElementById('toast');
      document.getElementById('toastMessage').innerText = msg;
      toast.className = `fixed top-4 right-4 z-50 transform px-5 py-3 rounded-xl shadow-xl flex items-center gap-3 text-white text-sm font-bold transition-all duration-300 ${tipo === 'success' ? 'bg-emerald-600' : 'bg-rose-600'}`;
      document.getElementById('toastIcon').className = tipo === 'success' ? 'fas fa-check-circle' : 'fas fa-exclamation-triangle';
      setTimeout(() => toast.classList.remove('translate-y-[-100%]', 'opacity-0'), 10);
      setTimeout(() => toast.classList.add('translate-y-[-100%]', 'opacity-0'), 4000);
    }

    function activarDashboard() {
      document.getElementById('pantalla-login').classList.add('hidden');
      document.getElementById('pantalla-app').classList.replace('hidden', 'flex');
      document.getElementById('ui-username').innerText = sessionUser.nombre;
      cambiarTab('tab-clientes');
    }
    
    function cerrarSesion() { sessionStorage.removeItem('g4s_user'); window.location.reload(); }

    function cambiarTab(id) {
      document.querySelectorAll('.tab-content').forEach(el => el.classList.add('hidden'));
      document.querySelectorAll('.tab-btn').forEach(el => { el.classList.replace('bg-rose-600', 'text-slate-300'); el.classList.replace('text-white', 'hover:bg-slate-700'); });
      document.getElementById(id).classList.remove('hidden');
      const btn = document.getElementById('btn-' + id);
      btn.classList.replace('text-slate-300', 'bg-rose-600'); btn.classList.replace('hover:bg-slate-700', 'text-white');
      
      if(id === 'tab-actas') { document.getElementById('act-fecha').value = new Date().toISOString().split('T')[0]; document.getElementById('act-asist-g4s').value = sessionUser.nombre; document.getElementById('act-cargo-g4s').value = sessionUser.cargo; cargarClientesEnSelect(); }
      if(id === 'tab-historial' && dbHistorial.length === 0) cargarHistorial();
    }

    async function ejecutarLogin(e) {
      e.preventDefault();
      const u = document.getElementById('login-user').value; const c = document.getElementById('login-pass').value;
      const btn = document.getElementById('btn-login'); 
      btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i> Conectando...';

      const res = await pushData('login', { user: u, pass: c });
      btn.disabled = false; btn.innerHTML = 'Ingresar al Sistema';
      
      if (res.success) {
        sessionUser = res; sessionUser.usuarioID = u;
        sessionStorage.setItem('g4s_user', JSON.stringify(sessionUser));
        activarDashboard(); mostrarToast("Bienvenido " + res.nombre, "success");
      } else mostrarToast(res.message, "error");
    }

    async function registrarCliente(e) {
      e.preventDefault();
      const btn = document.getElementById('btn-cliente'); btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i> Guardando...';
      const data = { nombre: document.getElementById('cli-nombre').value, correo: document.getElementById('cli-correo').value, direccion: document.getElementById('cli-direccion').value, telefono: document.getElementById('cli-telefono').value, cargoContacto: document.getElementById('cli-cargo').value, usuarioActual: sessionUser.nombre };
      
      const res = await pushData('guardarCliente', data);
      btn.disabled = false; btn.innerHTML = '<i class="fas fa-save mr-1"></i> Guardar Cliente';
      if(res.success) { mostrarToast("Cliente guardado", "success"); e.target.reset(); } else mostrarToast("Error: " + res.message, "error");
    }

    async function cargarClientesEnSelect() {
      const select = document.getElementById('act-cliente'); select.innerHTML = '<option value="">Cargando clientes...</option>';
      const res = await pushData('obtenerClientes', {});
      if (res && Array.isArray(res)) {
        dbClientes = res; select.innerHTML = '<option value="">-- Seleccione Cliente --</option>';
        res.forEach((c, idx) => select.innerHTML += `<option value="${idx}">${c.nombre}</option>`);
      } else select.innerHTML = '<option value="">Error al cargar</option>';
    }

    function autoCompletarCliente() {
      const idx = document.getElementById('act-cliente').value;
      if (idx !== "") { const c = dbClientes[idx]; document.getElementById('act-direccion').value = c.direccion; document.getElementById('act-asist-cli').value = c.nombre; document.getElementById('act-cargo-cli').value = c.cargoContacto; document.getElementById('act-correo-cli').value = c.correo; }
    }

    async function generarActa(e) {
      e.preventDefault();
      const btn = document.getElementById('btn-acta'); btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i> Procesando...';
      const select = document.getElementById('act-cliente');
      const datos = { clienteNombre: select.options[select.selectedIndex].text, clienteCorreo: document.getElementById('act-correo-cli').value, fecha: document.getElementById('act-fecha').value, ciudad: document.getElementById('act-ciudad').value, direccion: document.getElementById('act-direccion').value, asistentesCliente: document.getElementById('act-asist-cli').value, cargoCliente: document.getElementById('act-cargo-cli').value, asistentesG4S: document.getElementById('act-asist-g4s').value, cargoG4S: document.getElementById('act-cargo-g4s').value, temasTratados: document.getElementById('act-temas').value, conclusiones: document.getElementById('act-conclusiones').value, usuarioNombre: sessionUser.nombre, usuarioCorreo: sessionUser.correo };

      const res = await pushData('crearActa', datos);
      btn.disabled = false; btn.innerHTML = '<i class="fas fa-paper-plane mr-2"></i> Emitir Acta Oficial';
      
      if(res.success) {
        mostrarToast("Acta emitida con éxito", "success");
        if(res.pdfBase64 && document.getElementById('act-descargar').checked) { const link = document.createElement('a'); link.href = 'data:application/pdf;base64,' + res.pdfBase64; link.download = `Acta_${res.id}.pdf`; document.body.appendChild(link); link.click(); document.body.removeChild(link); }
        e.target.reset(); cambiarTab('tab-actas');
      } else mostrarToast("Error: " + res.message, "error");
    }

    async function cargarHistorial() {
      const tbody = document.getElementById('tabla-historial'); tbody.innerHTML = `<tr><td colspan="5" class="p-6 text-center"><i class="fas fa-spinner fa-spin text-xl text-rose-500 mb-2"></i><br>Cargando datos...</td></tr>`;
      const res = await pushData('obtenerHistorial', { usuario: sessionUser.nombre });
      if (res && Array.isArray(res)) { dbHistorial = res; aplicarFiltros(); } else tbody.innerHTML = `<tr><td colspan="5" class="p-6 text-center text-rose-500">Error al cargar.</td></tr>`;
    }

    function aplicarFiltros() {
      const fDesde = document.getElementById('filtro-desde').value; const fHasta = document.getElementById('filtro-hasta').value; const fCliente = document.getElementById('filtro-cliente').value.toLowerCase();
      let filt = dbHistorial.filter(h => {
        let match = true; let d = null;
        const parts = h.fecha.split(/[-/]/);
        if(parts.length === 3) d = parts[0].length === 4 ? new Date(parts[0], parts[1]-1, parts[2]) : new Date(parts[2], parts[1]-1, parts[0]);
        if (fCliente && !h.cliente.toLowerCase().includes(fCliente)) match = false;
        if (d) { if (fDesde && d < new Date(fDesde)) match = false; if (fHasta && d > new Date(fHasta)) match = false; }
        return match;
      });
      const tbody = document.getElementById('tabla-historial');
      if (filt.length === 0) { tbody.innerHTML = `<tr><td colspan="5" class="p-6 text-center text-slate-400">No hay registros.</td></tr>`; return; }
      tbody.innerHTML = filt.map(h => `<tr class="hover:bg-slate-50 border-b border-slate-50"><td class="p-4 font-mono text-xs font-black text-rose-600">${h.id}</td><td class="p-4 text-xs font-bold">${h.fecha}</td><td class="p-4 text-xs font-black text-slate-700">${h.cliente}</td><td class="p-4 text-xs text-slate-600">${h.ciudad}</td><td class="p-4 text-xs text-slate-500 max-w-xs truncate">${h.conclusiones}</td></tr>`).join('');
    }
  </script>
</body>
</html>
